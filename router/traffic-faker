#!/bin/sh
# traffic-faker — DEV ONLY. Writes synthetic ping samples (baseline jitter +
# occasional spikes + occasional loss) to the ring buffer so the badge
# net_traffic graph shows lively data instead of a flat real connection.
# awk-driven (no $RANDOM / usleep needed). Appends 5 new samples each second,
# matching ~5 pings/sec at the badge's 1 Hz poll. Run INSTEAD of traffic-pinger
# while developing:
#     /etc/init.d/traffic-pinger stop; /etc/init.d/traffic-pinger disable
#     /tmp/traffic-faker pppoe-ppp0 &
IFACE="${1:-pppoe-ppp0}"
RING="/tmp/traffic_ping_$IFACE"
exec awk -v ring="$RING" 'BEGIN{
  srand();
  for (i = 0; i < 32; i++) a[i] = 20;            # seed at baseline
  while (1) {
    for (k = 0; k < 5; k++) {                     # 5 new samples per second
      r = int(rand() * 100);
      if      (r < 4)  v = -1;                     # ~4% loss
      else if (r < 14) v = 45 + int(rand() * 85);  # ~10% spike 45-129ms
      else             v = 14 + int(rand() * 12);  # baseline 14-25ms
      for (i = 0; i < 31; i++) a[i] = a[i + 1];     # shift left
      a[31] = v;                                    # append newest
    }
    s = a[0]; for (i = 1; i < 32; i++) s = s " " a[i];
    tmp = ring ".tmp"; print s > tmp; close(tmp);
    system("mv " tmp " " ring);
    system("sleep 1");
  }
}'
