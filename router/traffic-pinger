#!/bin/sh
# traffic-pinger — per-WAN latency ring-buffer daemon for the net_traffic CGI v2.
# Runs as a persistent daemon (managed by procd). For each WAN interface defined in
# /etc/traffic.conf (<iface> <name> <down_mbps> <up_mbps> [ping_target]) it issues
# "ping -I <iface> -c1 -W1 <target>" ~5x/sec and keeps the last 32 RTT samples
# (ms, decimals; -1 = loss/timeout) in /tmp/traffic_ping_<iface>, newest last.
#
# The optional 5th field is a per-WAN ping target (default 8.8.8.8). Pointing both
# WANs at a provider-homed IP makes their graphs diverge by the peering distance —
# e.g. a KPN IP is on-net for the KPN WAN but a peering hop away for the other.
#
# POSIX sh (busybox ash) — no extra packages needed.
# Install: /usr/bin/traffic-pinger  (managed via /etc/init.d/traffic-pinger)

CONF=/etc/traffic.conf
DEFAULT_TARGET=8.8.8.8
HIST_LEN=32

# Emit "<iface> <target>" per WAN from conf, or auto-detect the default-route iface.
get_targets() {
    if [ -f "$CONF" ]; then
        grep -vE '^[[:space:]]*(#|$)' "$CONF" | while read -r iface name dmax umax target rest; do
            [ -z "$iface" ] && continue
            [ -z "$target" ] && target="$DEFAULT_TARGET"
            echo "$iface $target"
        done
    else
        dev=$(ip route get "$DEFAULT_TARGET" 2>/dev/null | sed -n 's/.* dev \([^ ]*\).*/\1/p' | head -1)
        [ -n "$dev" ] && echo "$dev $DEFAULT_TARGET"
    fi
}

# Ping once on iface to target; echo RTT (ms, decimals) or -1.
ping_once() {
    local iface="$1" target="$2" out rtt
    out=$(ping -4 -I "$iface" -c1 -W1 "$target" 2>/dev/null)
    rtt=$(printf '%s\n' "$out" | sed -n 's/.*time=\([0-9.]*\).*/\1/p' | head -1)
    if [ -n "$rtt" ]; then
        printf '%s' "$rtt"
    else
        printf '%s' "-1"
    fi
}

# Append rtt to ring buffer for iface, keeping last HIST_LEN entries.
update_ring() {
    local iface="$1"
    local rtt="$2"
    local ringfile="/tmp/traffic_ping_${iface}"
    local existing=""
    [ -f "$ringfile" ] && existing=$(cat "$ringfile")

    # Set positional params to current entries; shift to keep last (HIST_LEN-1).
    # shellcheck disable=SC2086
    set -- $existing
    while [ "$#" -ge "$HIST_LEN" ]; do
        shift
    done
    # Write updated ring (leading space from $* is harmless for consumers).
    printf '%s\n' "$* $rtt" > "$ringfile"

    # Bump the monotonic sample counter the CGI exposes as "seq" so the badge can
    # scroll by the exact number of new samples since its last poll.
    local seqfile="/tmp/traffic_seq_${iface}"
    local seq=0
    [ -f "$seqfile" ] && seq=$(cat "$seqfile")
    printf '%s\n' "$((seq + 1))" > "$seqfile"
}

# Main loop — runs forever, cycling through WANs.
while true; do
    targets=$(get_targets)
    if [ -z "$targets" ]; then
        sleep 1
        continue
    fi
    # ~5 samples/sec/WAN to match the badge's ping_rate. A flat-out loop on a fast
    # link emits dozens/sec and outruns the badge's play-head; pace it here (5 then
    # sleep 1 — bursty, but the badge's jitter buffer absorbs it, and the back-to-
    # back burst captures GPON-style micro-jitter that 1s sampling would smooth).
    echo "$targets" | while read -r iface target; do
        [ -z "$iface" ] && continue
        k=0
        while [ "$k" -lt 5 ]; do
            rtt=$(ping_once "$iface" "$target")
            update_ring "$iface" "$rtt"
            k=$((k + 1))
        done
    done
    sleep 1
done
